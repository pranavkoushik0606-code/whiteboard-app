# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (local via docker-compose, or your own MongoDB Atlas URI)
MONGO_URI=mongodb://localhost:27017/whiteboard

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Email (no signup needed — Ethereal test inbox is auto-created in code,
# these vars are only used if you later swap in a real SMTP provider)
EMAIL_FROM=noreply@whiteboard.dev
